# Rhinalx configuration — copy to .env and fill in.
# The .env file is gitignored; never commit real keys.

# --- Reasoning backend selection ---
# claude  = use the Anthropic API when allowed, fall back to local Ollama on failure
# local   = use the local Ollama LLM only (fully offline, no cloud calls)
POLICY=claude

# --- Anthropic (reasoning path; used only when POLICY=claude) ---
# Read from the environment — never hardcode this in code.
ANTHROPIC_API_KEY=
# Default reasoning model. Escalate hardest consolidation to claude-opus-4-8 only if needed.
MODEL=claude-sonnet-5

# --- Ollama (local models) ---
OLLAMA_HOST=http://localhost:11434
EMBED_MODEL=nomic-embed-text
LOCAL_LLM_MODEL=llama3.1:8b

# --- Store ---
# Single-file, inspectable local memory.
DB_PATH=data/rhinalx.db
